      <material name="white_material" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://quadruped_robot/meshes/RL_thigh.STL" />
      </geometry>
    </collision>
  </link>
  <!-- 后左大腿关节：旋转关节，连接后左髋部-后左大腿 -->
  <joint name="rl_thigh_joint" type="revolute">
    <origin xyz="-0.034 0.0254 0" rpy="0 0 0" />
    <parent link="rl_hip" />
    <child link="rl_thigh" />
    <axis xyz="0 1 0" />        <!-- 旋转轴方向：Y轴正方向 -->
    <limit lower="-0.5236" upper="0.5236" effort="2" velocity="4.7124" />
  </joint>

  <!-- ===================== 后左腿(RL)：小腿 连杆+关节 ===================== -->
  <!-- 后左小腿连杆：rl_calf -->
  <link name="rl_calf">
    <inertial>
      <origin xyz="-0.1346 0.1313 -0.1304" rpy="0 0 0" />
      <mass value="0.0403" />
      <inertia ixx="0.0014" ixy="0.0007" ixz="-0.0007" iyy="0.0015" iyz="0.0007" izz="0.0014" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://quadruped_robot/meshes/RL_calf.STL" />
      </geometry>
      <material name="white_material" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://quadruped_robot/meshes/RL_calf.STL" />
      </geometry>
    </collision>
  </link>
  <!-- 后左小腿关节：旋转关节，连接后左大腿-后左小腿 -->
  <joint name="rl_calf_joint" type="revolute">
    <origin xyz="0 0.0604 -0.12" rpy="0 0 0" />
    <parent link="rl_thigh" />
    <child link="rl_calf" />
    <axis xyz="0 1 0" />        <!-- 旋转轴方向：Y轴正方向 -->
    <limit lower="-0.5236" upper="0.5236" effort="2" velocity="4.7124" />
  </joint>

  <!-- ===================== 后左腿(RL)：脚部 连杆+固定关节 ===================== -->
  <!-- 后左脚部连杆：rl_foot -->
  <link name="rl_foot">
    <inertial>
      <origin xyz="-0.1395 0.1308 -0.199" rpy="0 0 0" />
      <mass value="0.0066" />
      <inertia ixx="0.0004" ixy="0.0001" ixz="-0.0002" iyy="0.0004" iyz="0.0002" izz="0.0002" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://quadruped_robot/meshes/RL_foot.STL" />
      </geometry>
      <material name="white_material" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://quadruped_robot/meshes/RL_foot.STL" />
      </geometry>
    </collision>
  </link>
  <!-- 后左脚部关节：固定关节，连接后左小腿-后左脚部 -->
  <joint name="rl_foot_joint" type="fixed">
    <origin xyz="-0.00206 0.00006 -0.13694" rpy="0 0 0" />
    <parent link="rl_calf" />
    <child link="rl_foot" />
  </joint>

  <!-- ===================== 后右腿(RR)：髋部 连杆+关节 ===================== -->
  <!-- 后右髋部连杆：rr_hip -->
  <link name="rr_hip">
    <inertial>
      <origin xyz="-0.1441 -0.0389 0.0424" rpy="0 0 0" />
      <mass value="0.2924" />
      <inertia ixx="0.0011" ixy="-0.0016" ixz="0.0018" iyy="0.0067" iyz="0.0005" izz="0.0066" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://quadruped_robot/meshes/RR_hip.STL" />
      </geometry>
      <material name="white_material" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://quadruped_robot/meshes/RR_hip.STL" />
      </geometry>
    </collision>
  </link>
  <!-- 后右髋关节：旋转关节，连接基座-后右髋部 -->
  <joint name="rr_hip_joint" type="revolute">
    <origin xyz="-0.0909 -0.04 0" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="rr_hip" />
    <axis xyz="1 0 0" />        <!-- 旋转轴方向：X轴正方向 -->
    <limit lower="-0.5236" upper="0.5236" effort="2" velocity="4.7124" />
  </joint>

  <!-- ===================== 后右腿(RR)：大腿 连杆+关节 ===================== -->
  <!-- 后右大腿连杆：rr_thigh -->
  <link name="rr_thigh">
    <inertial>
      <origin xyz="-0.1467 -0.0977 0.0309" rpy="0 0 0" />
      <mass value="0.4104" />
      <inertia ixx="0.0049" ixy="-0.0059" ixz="0.0018" iyy="0.0097" iyz="0.0011" izz="0.013" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://quadruped_robot/meshes/RR_thigh.STL" />
      </geometry>
      <material name="white_material" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://quadruped_robot/meshes/RR_thigh.STL" />
      </geometry>
    </collision>
  </link>
  <!-- 后右大腿关节：旋转关节，连接后右髋部-后右大腿 -->
  <joint name="rr_thigh_joint" type="revolute">
    <origin xyz="-0.034 -0.0254 0" rpy="0 0 0" />
    <parent link="rr_hip" />
    <child link="rr_thigh" />
    <axis xyz="0 -1 0" />       <!-- 旋转轴方向：Y轴负方向 -->
    <limit lower="-0.5236" upper="0.5236" effort="2" velocity="4.7124" />
  </joint>

  <!-- ===================== 后右腿(RR)：小腿 连杆+关节 ===================== -->
  <!-- 后右小腿连杆：rr_calf -->
  <link name="rr_calf">
    <inertial>
      <origin xyz="-0.1346 -0.1201 -0.1305" rpy="0 0 0" />
      <mass value="0.0403" />
      <inertia ixx="0.0013" ixy="-0.0007" ixz="-0.0007" iyy="0.0015" iyz="-0.0006" izz="0.0013" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://quadruped_robot/meshes/RR_calf.STL" />
      </geometry>
      <material name="white_material" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://quadruped_robot/meshes/RR_calf.STL" />
      </geometry>
    </collision>
  </link>
  <!-- 后右小腿关节：旋转关节，连接后右大腿-后右小腿 -->
  <joint name="rr_calf_joint" type="revolute">
    <origin xyz="0 -0.0604 -0.12" rpy="0 0 0" />
    <parent link="rr_thigh" />
    <child link="rr_calf" />
    <axis xyz="0 1 0" />        <!-- 旋转轴方向：Y轴正方向 -->
    <limit lower="-0.5236" upper="0.5236" effort="2" velocity="4.7124" />
  </joint>

  <!-- ===================== 后右腿(RR)：脚部 连杆+固定关节 ===================== -->
  <!-- 后右脚部连杆：rr_foot -->
  <link name="rr_foot">
    <inertial>
      <origin xyz="-0.1395 -0.1208 -0.199" rpy="0 0 0" />
      <mass value="0.0066" />
      <inertia ixx="0.0004" ixy="-0.0001" ixz="-0.0002" iyy="0.0004" iyz="-0.0002" izz="0.0002" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://quadruped_robot/meshes/RR_foot.STL" />
      </geometry>
      <material name="white_material" />
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://quadruped_robot/meshes/RR_foot.STL" />
      </geometry>
    </collision>
  </link>
  <!-- 后右脚部关节：固定关节，连接后右小腿-后右脚部 -->
  <joint name="rr_foot_joint" type="fixed">
    <origin xyz="-0.00206 0.00006 -0.13694" rpy="0 0 0" />
    <parent link="rr_calf" />
    <child link="rr_foot" />
  </joint>

</robot>